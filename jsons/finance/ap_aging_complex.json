          "key": "query",
          "value": "SELECT invoice_id, vendor_id, invoice_date, due_date, invoice_amount, paid_amount, status, company_code FROM ap_invoices WHERE company_code = '${company_code}' AND status != 'CANCELLED'"
        }
      ]
