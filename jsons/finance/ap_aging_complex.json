  "derivedDfPipelineMappingMP": [
    {
      "ID": "invoice_base_df",
      "Options": [
        {
          "key": "col(oracle_invoices_df.invoice_id).alias(invoice_id)"
        },
        {
          "key": "col(oracle_invoices_df.vendor_id).alias(vendor_id)"
        },
        {
          "key": "col(oracle_invoices_df.invoice_date).alias(invoice_date)"
        },
        {
          "key": "col(oracle_invoices_df.due_date).alias(due_date)"
        },
        {
          "key": "expr(oracle_invoices_df.invoice_amount - oracle_invoices_df.paid_amount).alias(outstanding_amount)"
        },
        {
          "key": "expr(DATEDIFF('${report_date}', oracle_invoices_df.due_date)).alias(days_past_due)"
        }
      ]
    },
    {
      "ID": "invoice_base_df.srcFilter",
      "Options": [
        {
          "key": "expr(oracle_invoices_df.invoice_amount > oracle_invoices_df.paid_amount)"
        }
      ]
    },
    {
      "ID": "vendor_map_df",
      "Options": [
        {
          "key": "col(mysql_vendors_df.vendor_id).alias(vendor_id)"
        },
        {
          "key": "col(mysql_vendors_df.vendor_name).alias(vendor_name)"
        },
        {
          "key": "col(mysql_vendors_df.payment_terms).alias(payment_terms)"
        },
        {
          "key": "col(mysql_vendors_df.vendor_type).alias(vendor_type)"
        }
      ]
    },
    {
      "ID": "ap_with_vendor_df",
      "Options": [
        {
          "key": "col(invoice_base_df.invoice_id).alias(invoice_id)"
        },
        {
          "key": "col(invoice_base_df.outstanding_amount).alias(outstanding_amount)"
        },
        {
          "key": "col(invoice_base_df.days_past_due).alias(days_past_due)"
        },
        {
          "key": "col(vendor_map_df.vendor_name).alias(vendor_name)"
        },
        {
          "key": "col(vendor_map_df.vendor_type).alias(vendor_type)"
        },
        {
          "key": "expr(CASE WHEN invoice_base_df.days_past_due <= 0 THEN 'CURRENT' WHEN invoice_base_df.days_past_due <= 30 THEN '1-30' WHEN invoice_base_df.days_past_due <= 60 THEN '31-60' WHEN invoice_base_df.days_past_due <= 90 THEN '61-90' ELSE '90+' END).alias(aging_bucket)"
        }
      ]
    },
    {
      "ID": "ap_with_vendor_df.joinExpression",
      "Options": [
        {
          "key": "expr(invoice_base_df.vendor_id == vendor_map_df.vendor_id)"
        }
      ]
    },
    {
      "ID": "ap_aging_summary_df.groupBy",
      "Options": [
        {
          "key": "col(vendor_name)"
        },
        {
          "key": "col(vendor_type)"
        },
        {
          "key": "col(aging_bucket)"
        }
      ]
    },
    {
      "ID": "ap_aging_summary_df.agg",
      "Options": [
        {
          "key": "expr(SUM(outstanding_amount)).alias(total_outstanding)"
        },
        {
          "key": "expr(COUNT(invoice_id)).alias(invoice_count)"
        },
        {
          "key": "expr(AVG(outstanding_amount)).alias(avg_invoice_amount)"
        },
        {
          "key": "expr(MAX(days_past_due)).alias(max_days_overdue)"
        }
      ]
    },
    {
      "ID": "ap_aging_summary_df.sort",
      "Options": [
        {
          "key": "col(vendor_name)"
        },
        {
          "key": "col(aging_bucket)"
        }
      ]
    }
  ],
