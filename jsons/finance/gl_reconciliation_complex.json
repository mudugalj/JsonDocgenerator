          "key": "col(oracle_coa_df.account_type).alias(account_type)"
        }
      ]
    },
    {
      "ID": "gl_enriched_df.joinExpression",
      "Options": [
        {
          "key": "expr(gl_with_costcenter_df.account_code == oracle_coa_df.account_code)"
        }
      ]
    },
    {
      "ID": "gl_recon_summary_df.groupBy",
      "Options": [
        {
          "key": "col(account_code)"
