        {
          "key": "col(account_name)"
        },
        {
          "key": "col(account_type)"
        },
        {
          "key": "col(cost_center_name)"
        }
      ]
    },
    {
      "ID": "gl_recon_summary_df.agg",
      "Options": [
        {
          "key": "expr(SUM(net_amount)).alias(total_net_amount)"
        },
        {
          "key": "expr(COUNT(journal_id)).alias(entry_count)"
        },
        {
          "key": "expr(SUM(CASE WHEN net_amount > 0 THEN net_amount ELSE 0 END)).alias(total_debit)"
        },
        {
          "key": "expr(SUM(CASE WHEN net_amount < 0 THEN ABS(net_amount) ELSE 0 END)).alias(total_credit)"
        }
      ]
    },
    {
      "ID": "gl_recon_summary_df.sort",
      "Options": [
