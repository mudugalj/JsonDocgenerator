  "srcDFsOptionsMP": [
    {
      "ID": "700700701.OPTIONS",
      "Options": [
        {
          "key": "query",
          "value": "SELECT campaign_id, channel, spend_amount, impressions, clicks, spend_date FROM campaign_spend WHERE spend_date BETWEEN '${campaign_start}' AND '${campaign_end}' AND spend_amount >= ${min_spend_threshold}"
        }
      ]
    },
    {
      "ID": "700700702.OPTIONS",
      "Options": [
        {
          "key": "query",
          "value": "SELECT conversion_id, campaign_id, customer_id, conversion_date, revenue_amount, product_category, attribution_model FROM conversions WHERE conversion_date BETWEEN '${campaign_start}' AND '${campaign_end}'"
        }
      ]
    },
    {
      "ID": "700700703.OPTIONS",
      "Options": [
        {
          "key": "path",
          "value": "/app/seed-data/customer_segments.parquet"
        },
        {
          "key": "sourceFilter",
          "value": "segment_name IS NOT NULL"
        }
      ]
    }
  ],
  "derivedDfPipelineMappingMP": [
    {
      "ID": "spend_agg_df",
      "Options": [
        {
          "key": "col(mysql_spend_df.campaign_id).alias(campaign_id)"
        },
        {
          "key": "col(mysql_spend_df.channel).alias(channel)"
        },
        {
          "key": "col(mysql_spend_df.spend_amount).alias(spend_amount)"
        },
        {
          "key": "col(mysql_spend_df.impressions).alias(impressions)"
        },
        {
          "key": "col(mysql_spend_df.clicks).alias(clicks)"
        },
        {
          "key": "expr(mysql_spend_df.clicks * 100.0 / mysql_spend_df.impressions).alias(click_through_rate)"
        }
      ]
    },
    {
      "ID": "spend_agg_df.srcFilter",
      "Options": [
        {
          "key": "expr(mysql_spend_df.impressions > 0)"
        }
      ]
    },
    {
      "ID": "conversion_with_segment_df",
      "Options": [
        {
          "key": "col(hive_conversion_df.conversion_id).alias(conversion_id)"
        },
        {
          "key": "col(hive_conversion_df.campaign_id).alias(campaign_id)"
        },
        {
          "key": "col(hive_conversion_df.revenue_amount).alias(revenue_amount)"
        },
        {
          "key": "col(hive_conversion_df.product_category).alias(product_category)"
        },
        {
          "key": "col(parquet_segments_df.segment_name).alias(segment_name)"
        },
        {
          "key": "col(parquet_segments_df.lifetime_value_tier).alias(ltv_tier)"
        }
      ]
    },
    {
      "ID": "conversion_with_segment_df.joinExpression",
      "Options": [
        {
          "key": "expr(hive_conversion_df.customer_id == parquet_segments_df.customer_id)"
        }
      ]
    },
    {
      "ID": "conversion_with_segment_df.srcBFilter",
      "Options": [
        {
          "key": "expr(parquet_segments_df.is_active == true)"
        }
      ]
    },
    {
      "ID": "campaign_roi_df",
      "Options": [
        {
          "key": "col(spend_agg_df.campaign_id).alias(campaign_id)"
        },
        {
          "key": "col(spend_agg_df.channel).alias(channel)"
        },
        {
          "key": "col(spend_agg_df.spend_amount).alias(spend_amount)"
        },
        {
          "key": "col(spend_agg_df.click_through_rate).alias(ctr)"
        },
        {
          "key": "col(conversion_with_segment_df.revenue_amount).alias(revenue_amount)"
        },
        {
          "key": "col(conversion_with_segment_df.segment_name).alias(segment_name)"
        },
        {
          "key": "col(conversion_with_segment_df.ltv_tier).alias(ltv_tier)"
        }
      ]
    },
    {
      "ID": "campaign_roi_df.joinExpression",
      "Options": [
        {
          "key": "expr(spend_agg_df.campaign_id == conversion_with_segment_df.campaign_id)"
        }
      ]
    },
    {
      "ID": "campaign_roi_df.srcAFilter",
      "Options": [
        {
          "key": "expr(spend_agg_df.spend_amount > 0)"
        }
      ]
    },
    {
      "ID": "roi_summary_df.groupBy",
      "Options": [
        {
          "key": "col(channel)"
        },
        {
          "key": "col(segment_name)"
        },
        {
          "key": "col(ltv_tier)"
        }
      ]
    },
    {
      "ID": "roi_summary_df.agg",
      "Options": [
        {
          "key": "expr(SUM(spend_amount)).alias(total_spend)"
        },
        {
          "key": "expr(SUM(revenue_amount)).alias(total_revenue)"
        },
        {
          "key": "expr((SUM(revenue_amount) - SUM(spend_amount)) / SUM(spend_amount) * 100).alias(roi_pct)"
        },
        {
          "key": "expr(COUNT(DISTINCT campaign_id)).alias(campaign_count)"
        },
        {
          "key": "expr(AVG(ctr)).alias(avg_ctr)"
        }
      ]
    },
    {
      "ID": "roi_summary_df.sort",
      "Options": [
        {
          "key": "col(roi_pct).desc()"
        },
        {
          "key": "col(total_revenue).desc()"
        }
      ]
    }
  ],
