  "srcDFsOptionsMP": [
    {
      "ID": "400400401.OPTIONS",
      "Options": [
        {
          "key": "query",
          "value": "SELECT txn_id, rep_id, customer_id, product_id, sale_amount, discount_pct, txn_date, is_renewal FROM sales_transactions WHERE TO_CHAR(txn_date, 'YYYY-MM') = '${commission_period}' AND status = 'CLOSED_WON'"
        }
      ]
    },
    {
      "ID": "400400402.OPTIONS",
      "Options": [
        {
          "key": "query",
          "value": "SELECT rep_id, rep_name, manager_id, annual_quota, commission_rate, accelerator_rate, tier FROM rep_targets WHERE fiscal_year = 2025 AND is_active = 1"
        }
      ]
    },
    {
      "ID": "400400403.OPTIONS",
      "Options": [
        {
          "key": "dbtable",
          "value": "(SELECT rep_id, SUM(credited_amount) AS ytd_credited FROM sales_credits WHERE fiscal_year = 2025 AND period < '${commission_period}' GROUP BY rep_id) tmp"
        }
      ]
    }
  ],
