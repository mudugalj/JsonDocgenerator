  "derivedDfPipelineMappingMP": [
    {
      "ID": "stock_base_df",
      "Options": [
        {
          "key": "col(oracle_stock_df.warehouse_id).alias(warehouse_id)"
        },
        {
          "key": "col(oracle_stock_df.sku).alias(sku)"
        },
        {
          "key": "col(oracle_stock_df.product_name).alias(product_name)"
        },
        {
          "key": "col(oracle_stock_df.quantity_on_hand).alias(qty_on_hand)"
        },
        {
          "key": "col(oracle_stock_df.unit_cost).alias(unit_cost)"
        },
        {
          "key": "expr(oracle_stock_df.quantity_on_hand * oracle_stock_df.unit_cost).alias(inventory_value)"
        }
      ]
    },
    {
      "ID": "po_pending_df",
      "Options": [
        {
          "key": "col(mysql_po_df.po_id).alias(po_id)"
        },
        {
          "key": "col(mysql_po_df.sku).alias(sku)"
        },
        {
          "key": "col(mysql_po_df.supplier_id).alias(supplier_id)"
        },
        {
          "key": "expr(mysql_po_df.order_qty - mysql_po_df.received_qty).alias(pending_qty)"
        },
        {
          "key": "col(mysql_po_df.expected_delivery).alias(expected_delivery)"
        },
        {
          "key": "col(mysql_po_df.status).alias(po_status)"
        }
      ]
    },
    {
      "ID": "po_pending_df.srcFilter",
      "Options": [
        {
          "key": "expr(mysql_po_df.order_qty > mysql_po_df.received_qty)"
        }
      ]
    },
    {
      "ID": "stock_with_po_df",
      "Options": [
        {
          "key": "col(stock_base_df.warehouse_id).alias(warehouse_id)"
        },
        {
          "key": "col(stock_base_df.sku).alias(sku)"
        },
        {
          "key": "col(stock_base_df.product_name).alias(product_name)"
        },
        {
          "key": "col(stock_base_df.qty_on_hand).alias(qty_on_hand)"
        },
        {
          "key": "col(stock_base_df.unit_cost).alias(unit_cost)"
        },
        {
          "key": "col(stock_base_df.inventory_value).alias(inventory_value)"
        },
        {
          "key": "col(po_pending_df.pending_qty).alias(pending_qty)"
        },
        {
          "key": "col(po_pending_df.supplier_id).alias(supplier_id)"
        },
        {
          "key": "col(po_pending_df.expected_delivery).alias(expected_delivery)"
        }
      ]
    },
    {
      "ID": "stock_with_po_df.joinExpression",
      "Options": [
        {
          "key": "expr(stock_base_df.sku == po_pending_df.sku)"
        }
      ]
    },
    {
      "ID": "stock_with_demand_df",
      "Options": [
        {
          "key": "col(stock_with_po_df.warehouse_id).alias(warehouse_id)"
        },
        {
          "key": "col(stock_with_po_df.sku).alias(sku)"
        },
        {
          "key": "col(stock_with_po_df.product_name).alias(product_name)"
        },
        {
          "key": "col(stock_with_po_df.qty_on_hand).alias(qty_on_hand)"
        },
        {
          "key": "col(stock_with_po_df.unit_cost).alias(unit_cost)"
        },
        {
          "key": "col(stock_with_po_df.pending_qty).alias(pending_qty)"
        },
        {
          "key": "col(stock_with_po_df.supplier_id).alias(supplier_id)"
        },
        {
          "key": "col(parquet_demand_df.forecast_qty).alias(forecast_demand)"
        },
        {
          "key": "col(parquet_demand_df.forecast_period).alias(forecast_period)"
        },
        {
          "key": "expr(stock_with_po_df.qty_on_hand + COALESCE(stock_with_po_df.pending_qty, 0) - parquet_demand_df.forecast_qty).alias(projected_balance)"
        },
        {
          "key": "expr(parquet_demand_df.forecast_qty * ${safety_stock_multiplier}).alias(safety_stock_level)"
        }
      ]
    },
    {
      "ID": "stock_with_demand_df.joinExpression",
      "Options": [
        {
          "key": "expr(stock_with_po_df.sku == parquet_demand_df.sku)"
        },
        {
          "key": "expr(stock_with_po_df.warehouse_id == parquet_demand_df.warehouse_id)"
        }
      ]
    },
    {
      "ID": "reorder_calc_df.groupBy",
      "Options": [
        {
          "key": "col(warehouse_id)"
        },
        {
          "key": "col(sku)"
        },
        {
          "key": "col(product_name)"
        },
        {
          "key": "col(unit_cost)"
        },
        {
          "key": "col(supplier_id)"
        }
      ]
    },
    {
      "ID": "reorder_calc_df.agg",
      "Options": [
        {
          "key": "expr(MAX(qty_on_hand)).alias(current_stock)"
        },
        {
          "key": "expr(SUM(COALESCE(pending_qty, 0))).alias(total_pending)"
        },
        {
          "key": "expr(SUM(forecast_demand)).alias(total_forecast_demand)"
        },
        {
          "key": "expr(MAX(safety_stock_level)).alias(safety_stock)"
        },
        {
          "key": "expr(CASE WHEN (MAX(qty_on_hand) + SUM(COALESCE(pending_qty, 0)) - SUM(forecast_demand)) < MAX(safety_stock_level) THEN MAX(safety_stock_level) - (MAX(qty_on_hand) + SUM(COALESCE(pending_qty, 0)) - SUM(forecast_demand)) ELSE 0 END).alias(reorder_qty)"
        },
        {
          "key": "expr(CASE WHEN (MAX(qty_on_hand) + SUM(COALESCE(pending_qty, 0)) - SUM(forecast_demand)) < MAX(safety_stock_level) THEN (MAX(safety_stock_level) - (MAX(qty_on_hand) + SUM(COALESCE(pending_qty, 0)) - SUM(forecast_demand))) * MAX(unit_cost) ELSE 0 END).alias(reorder_value)"
        }
      ]
    },
    {
      "ID": "reorder_calc_df.sort",
      "Options": [
        {
          "key": "col(reorder_qty).desc()"
        },
        {
          "key": "col(warehouse_id)"
        }
      ]
    }
  ],
